# ── LinkLite Environment Variables ──────────────────────────────────────────────
# Copy this to .env and fill in your values

# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/linklite

# JWT secret for authentication (required — use a strong random string)
JWT_SECRET=your-secret-key-here-change-me

# Base URL for generating short links (required in production)
# Example: https://yourdomain.com
BASE_URL=http://localhost:3001

# Server port (default: 3000)
PORT=3000

# CORS origin (default: * for all, set to your frontend URL in production)
CORS_ORIGIN=*

# Redis URL (optional — the app works without Redis, but caching improves performance)
# REDIS_URL=redis://localhost:6379
