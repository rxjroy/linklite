{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/dist/index.js"
    },
    {
      "source": "/p/(.*)",
      "destination": "/dist/index.js"
    },
    {
      "source": "/(login|signup|dashboard|analytics|404)",
      "destination": "/index.html"
    },
    {
      "source": "/([^/.]+)",
      "destination": "/dist/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
